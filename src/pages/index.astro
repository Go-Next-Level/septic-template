---
import Base from '../layouts/Base.astro';
import { site, services, faqs } from '../config/site';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import SectionHeader from '../components/SectionHeader.astro';
import OfferBand from '../components/OfferBand.astro';
import WarrantyMaterials from '../components/WarrantyMaterials.astro';

const reviews = [
  { name: "Local Homeowner", rating: 5, text: "They arrived within two hours of my call. Found the blockage fast, pumped the tank, and left everything spotless. Incredible service.", location: `${site.address.city}, ${site.address.state}` },
  { name: "Property Manager", rating: 5, text: "We manage 12 rental properties. ClearFlow handles all our septic needs — pumping, inspections, and emergency calls. Always reliable.", location: site.serviceArea[1] ?? `${site.address.city}, ${site.address.state}` },
  { name: "New Homeowner", rating: 5, text: "Buying our first home with a septic system was intimidating. Their inspection report was clear, and they walked us through everything.", location: site.serviceArea[2] ?? `${site.address.city}, ${site.address.state}` },
  { name: "Local Customer", rating: 5, text: "Had a backup on a Sunday morning. Their emergency crew showed up fast, diagnosed the issue, and had us flowing again before noon.", location: site.serviceArea[3] ?? `${site.address.city}, ${site.address.state}` },
  { name: "Real Estate Agent", rating: 5, text: "I refer all my clients to ClearFlow for septic inspections. Their reports are thorough, digital, and delivered within 24 hours.", location: site.serviceArea[4] ?? `${site.address.city}, ${site.address.state}` },
  { name: "Restaurant Owner", rating: 5, text: "They handle our grease trap pumping and keep us compliant with county requirements. Professional, punctual, and fairly priced.", location: site.serviceArea[5] ?? `${site.address.city}, ${site.address.state}` },
];

const preview = (site as any).preview ?? {};
const displayReviews = preview.reviews ?? reviews;

const whyUs = [
  { title: "Licensed & Fully Insured", desc: "State-licensed septic contractor with full liability and workers' comp coverage on every crew. No subcontractors, no shortcuts.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />` },
  { title: "24/7 Emergency Response", desc: "Septic emergencies don't wait for business hours. Our emergency crew is on call nights, weekends, and holidays with fast dispatch.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />` },
  { title: "Satisfaction Guaranteed", desc: "Every service is backed by our written satisfaction guarantee. If something isn't right, we make it right — no arguments, no hassle.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />` },
  { title: "Clean Job Sites — Always", desc: "We protect your landscaping, cover walkways, and clean up thoroughly before we leave. Your property stays safe for family and pets.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />` },
];

const certifications = [
  "State Licensed Septic Contractor",
  "Certified Septic Inspector",
  "OSHA Safety Certified",
  "BBB A+ Rated",
  "EPA Compliant Disposal",
  "Emergency Response Team",
];
const displayCertifications = preview.certifications ?? certifications;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebSite", "@id": `${site.url}/#website`, "url": site.url, "name": site.name },
    {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
      "description": site.description,
      "url": site.url,
      "telephone": site.phone,
      "email": site.email,
      "foundingDate": String(site.founded),
      "address": { "@type": "PostalAddress", "streetAddress": site.address.street, "addressLocality": site.address.city, "addressRegion": site.address.state, "postalCode": site.address.zip, "addressCountry": "US" },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": site.rating, "reviewCount": site.reviewCount },
      "areaServed": site.serviceArea.map((city) => ({ "@type": "City", "name": city })),
    },
    { "@type": "FAQPage", "mainEntity": faqs.map((faq) => ({ "@type": "Question", "name": faq.q, "acceptedAnswer": { "@type": "Answer", "text": faq.a } })) },
  ],
};
---

<Base title={site.name} description={site.description} schema={schema}>

  <!-- ══════════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden" aria-labelledby="hero-heading">

    <!-- Background photo -->
    <div class="absolute inset-0">
      <img
        src="/images/septic/septic-hero-aerial.webp"
        alt={`Professional septic service work for ${site.name}`}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <!-- Contrast overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#06152B]/78 via-[#06152B]/56 to-[#06152B]/22"></div>
      <div class="absolute inset-0 bg-black/10"></div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 w-full">
      <div class="max-w-2xl">

        <!-- Eyebrow badge -->
        <div class="inline-flex items-center gap-2 bg-[#CC1720] text-white text-xs font-bold px-4 py-2 uppercase tracking-widest mb-8 anim-fadeInUp">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
          </span>
          {preview.eyebrow ?? `${site.address.city} Septic Services · Built Around Trust, Proof & Fast Response`}
        </div>

        <!-- Headline -->
        <h1
          id="hero-heading"
          class="font-['Barlow_Condensed'] font-black text-5xl sm:text-6xl lg:text-7xl xl:text-8xl leading-none uppercase text-white mb-6"
        >
          <span class="block anim-fadeInUp delay-100">{preview.heroLine1 ?? 'Clean Systems.'}</span>
          <span class="block anim-fadeInUp delay-200 text-[#CC1720]">{preview.heroLine2 ?? site.name}</span>
          <span class="block anim-fadeInUp delay-300">{preview.heroLine3 ?? 'Trusted Service.'}</span>
        </h1>

        <!-- Sub -->
        <p class="text-white/92 text-lg leading-relaxed mb-10 max-w-xl anim-fadeInUp delay-400 drop-shadow-[0_2px_8px_rgba(0,0,0,0.55)]">
          {preview.heroSub ?? `A sharper ${site.address.city} septic website concept for ${site.name}: clearer service paths, stronger proof, better mobile CTAs, and trust signals built for homeowners who need septic help now.`}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12 anim-fadeInUp delay-500">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#CC1720] text-white font-bold text-sm uppercase tracking-wider hover:bg-[#E31C26] transition-colors duration-200 shadow-lg shadow-red-900/40">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href={`tel:${site.phonePlain}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/30 text-white font-bold text-sm uppercase tracking-wider hover:bg-white/20 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {site.phone}
          </a>
        </div>

        <!-- Trust signals row -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 anim-fadeInUp delay-600 max-w-3xl">
          {[
            [`${site.rating}★`, "Review Trust"],
            [preview.stat2 ?? "24hr", preview.stat2Label ?? "Emergency Response"],
            [preview.stat3 ?? "$0", preview.stat3Label ?? "Estimate CTA"],
            [preview.stat4 ?? site.warranty, preview.stat4Label ?? "Satisfaction Guarantee"],
          ].map(([value, label]) => (
            <div class="border border-white/20 bg-white/10 backdrop-blur-sm px-4 py-3">
              <div class="font-['Barlow_Condensed'] text-3xl font-black text-white leading-none">{value}</div>
              <div class="text-blue-100/70 text-[10px] uppercase tracking-[0.18em] mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Floating review badge -->
      <div class="absolute bottom-32 right-6 lg:right-16 hidden lg:block anim-float">
        <div class="bg-white rounded-lg shadow-2xl p-4 w-56 border border-[#CDD8E8]">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-8 h-8 rounded-full bg-[#0A2447] flex items-center justify-center text-white text-xs font-bold">G</div>
            <div>
              <p class="text-[#0A1628] text-xs font-bold">Google Reviews</p>
              <div class="flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3 h-3 text-[#CC1720]" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-[#5B7394] text-xs italic">"{site.rating}/5 from {site.reviewCount} reviews"</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
      <span class="text-white text-xs uppercase tracking-widest">Scroll</span>
      <div class="w-0.5 h-8 bg-[#CC1720] animate-pulse"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       TRUST BAR
  ══════════════════════════════════════════════════════ -->
  <TrustBar />

  <OfferBand />

  <!-- ══════════════════════════════════════════════════════
       SERVICES
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 bg-[#F2F6FC]" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <SectionHeader eyebrow="What We Do" title="Every Septic Need.<br />One Trusted Crew." />
        <a href="/services/septic-pumping" class="reveal shrink-0 text-[#CC1720] text-sm font-semibold flex items-center gap-2 hover:gap-3 transition-all duration-200">
          All Services
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map((s, i) => (
          <div class="reveal" style={`transition-delay:${i*60}ms`}>
            <ServiceCard {...s} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       BEFORE / AFTER — SYSTEM TRANSFORMATION
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="ba-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-[#CC1720] text-xs font-bold uppercase tracking-[0.2em] mb-3">Real Results</p>
          <h2 id="ba-heading" class="font-['Barlow_Condensed'] font-black text-4xl lg:text-5xl text-[#0A2447] uppercase leading-tight mb-6 heading-accent">
            See the<br />Difference.
          </h2>
          <p class="text-[#5B7394] leading-relaxed mb-8">
            Every septic system we service gets the same meticulous attention — from thorough pumping and camera inspection to drain field evaluation and component testing. A properly maintained system protects your home, your health, and your property value.
          </p>
          <div class="flex flex-col gap-3 mb-8">
            {[
              "Complete tank pumping with level inspection",
              "Camera inspection to identify blockages and damage",
              "Drain field flow testing and evaluation",
              "Written maintenance plan and next-service reminder"
            ].map((point) => (
              <div class="flex items-center gap-3 text-sm text-[#0A1628]">
                <div class="w-5 h-5 rounded-full bg-[#CC1720] flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                {point}
              </div>
            ))}
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#0A2447] text-white font-bold text-sm uppercase tracking-wider hover:bg-[#1455A4] transition-colors duration-200">
            Schedule Free Inspection
          </a>
        </div>
        <div class="reveal relative">
          <img
            src="/images/septic/septic-pumping-service.webp"
            alt={`Professional septic tank pumping service by ${site.name}`}
            class="w-full h-[480px] object-cover shadow-2xl"
            loading="lazy"
          />
          <!-- Floating badge -->
          <div class="absolute -bottom-6 -right-6 bg-[#CC1720] text-white p-6 shadow-xl hidden lg:block">
            <div class="font-['Barlow_Condensed'] font-black text-4xl leading-none">{new Date().getFullYear() - site.founded}+</div>
            <div class="text-xs font-semibold uppercase tracking-wider mt-1 opacity-90">Years of Excellence</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <WarrantyMaterials />

  <!-- ══════════════════════════════════════════════════════
       WHY CHOOSE US (image + points)
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 section-navy clip-diagonal-bottom" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Image col -->
        <div class="relative reveal order-2 lg:order-1">
          <img
            src="/images/septic/septic-inspection-detail.webp"
            alt={`Professional septic system inspection by ${site.name}`}
            class="w-full h-[480px] object-cover shadow-2xl"
          />
        </div>

        <!-- Text col -->
        <div class="order-1 lg:order-2">
          <p class="text-[#CC1720] text-xs font-bold uppercase tracking-[0.2em] mb-3 reveal">Why {site.name}</p>
          <h2 id="why-heading" class="font-['Barlow_Condensed'] font-black text-4xl lg:text-5xl text-white uppercase leading-tight mb-8 reveal">
            We Earned Our<br /><span class="text-[#CC1720]">Reputation.</span>
          </h2>
          <div class="flex flex-col gap-5">
            {(preview.whyUs ?? whyUs).map((item, i) => (
              <div class="flex items-start gap-4 reveal" style={`transition-delay:${i*80}ms`}>
                <div class="w-10 h-10 rounded bg-white/10 border border-white/20 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={item.icon} />
                </div>
                <div>
                  <h3 class="text-white font-bold text-sm mb-1">{item.title}</h3>
                  <p class="text-blue-200/70 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-10 reveal">
            <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-[#CC1720] text-white font-bold text-sm uppercase tracking-wider hover:bg-[#E31C26] transition-colors duration-200">
              Schedule Free Inspection
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       PROCESS
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="process-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-xl mx-auto mb-16 reveal">
        <p class="text-[#CC1720] text-xs font-bold uppercase tracking-[0.2em] mb-3">How It Works</p>
        <h2 id="process-heading" class="font-['Barlow_Condensed'] font-black text-4xl lg:text-5xl text-[#0A2447] uppercase leading-tight heading-accent inline-block">
          Simple. Transparent.<br />No Surprises.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative">
        <!-- Connecting line (desktop) -->
        <div class="hidden md:block absolute top-12 left-1/6 right-1/6 h-0.5 bg-[#CDD8E8] z-0"></div>

        {[
          { num: "01", title: "Free Inspection", desc: "We locate your tank, assess the system, and document every component with photos. No pressure, no obligation — just an honest assessment delivered the same day.", img: "/images/septic/septic-tank-access.webp" },
          { num: "02", title: "Detailed Quote", desc: "You receive a written, line-item estimate with service specs, timeline, and warranty terms. No vague pricing, no hidden fees — ever.", img: "/images/septic/septic-inspection-detail.webp" },
          { num: "03", title: "Professional Service", desc: "Our licensed crew handles everything. You get a fully serviced system, a clean yard, and a signed completion report with next-service guidance.", img: "/images/septic/septic-pumping-service.webp" },
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center px-6 reveal" style={`transition-delay:${i*100}ms`}>
            <div class="relative mb-6 z-10">
              <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-[#CDD8E8] mx-auto">
                <img src={step.img} alt={step.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full bg-[#CC1720] text-white font-['Barlow_Condensed'] font-black text-sm flex items-center justify-center border-2 border-white">
                {step.num.slice(1)}
              </div>
            </div>
            <h3 class="font-['Barlow_Condensed'] font-bold text-xl text-[#0A2447] uppercase mb-3">{step.title}</h3>
            <p class="text-[#5B7394] text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       STATS COUNTER
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 bg-[#CC1720] clip-diagonal-bottom" aria-label="Company statistics">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center text-white">
        {[
          { target: new Date().getFullYear() - site.founded, suffix: "+", label: "Years in Business" },
          { target: site.systemsServiced, suffix: "+", label: "Systems Serviced" },
          { target: site.reviewCount, suffix: "+", label: "5-Star Reviews" },
          { target: 24, suffix: "hr", label: "Emergency Response" },
        ].map((stat, i) => (
          <div class="reveal" style={`transition-delay:${i*80}ms`}>
            <div class="font-['Barlow_Condensed'] font-black text-5xl lg:text-6xl mb-2 counter" data-target={stat.target} data-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="text-white/70 text-xs uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       REVIEWS
  ══════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 bg-[#F2F6FC] clip-diagonal-top" aria-labelledby="reviews-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-xl mx-auto mb-14 reveal">
        <p class="text-[#CC1720] text-xs font-bold uppercase tracking-[0.2em] mb-3">What Our Customers Say</p>
        <h2 id="reviews-heading" class="font-['Barlow_Condensed'] font-black text-4xl lg:text-5xl text-[#0A2447] uppercase leading-tight heading-accent inline-block">
          {site.rating}★ Average.<br />{site.reviewCount} Real Reviews.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {displayReviews.map((r, i) => (
          <div class="reveal" style={`transition-delay:${i*70}ms`}>
            <ReviewCard {...r} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       CERTIFICATIONS BAR
  ══════════════════════════════════════════════════════ -->
  <section class="py-10 bg-white border-y border-[#CDD8E8]" aria-label="Certifications and affiliations">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
