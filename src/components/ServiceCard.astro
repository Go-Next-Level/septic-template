---

<a
  href={`/services/${slug}`}
  class="group block bg-white border border-[#CDD8E8] p-6 hover:border-[#CC1720] hover:shadow-lg transition-all duration-300 cursor-pointer card-lift relative overflow-hidden"
>
  <!-- Top red accent bar (slides in on hover) -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-[#CC1720] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

  <!-- Icon -->
  <div class="w-12 h-12 rounded bg-[#F2F6FC] border border-[#CDD8E8] flex items-center justify-center mb-4 group-hover:bg-[#CC1720] group-hover:border-[#CC1720] transition-all duration-300">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#0A2447] group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={icons[icon] ?? icons.home} />
  </div>

  <h3 class="font-['Barlow_Condensed'] font-bold text-xl text-[#0A2447] uppercase mb-2 group-hover:text-[#CC1720] transition-colors duration-300">
    {title}
  </h3>
  <p class="text-[#5B7394] text-sm leading-relaxed mb-4">{short}</p>

  <div class="flex items-center gap-1.5 text-[#CC1720] text-sm font-semibold">
    Learn more
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</a>
