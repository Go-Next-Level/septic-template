---
import { site } from '../config/site';
---

<div
  id="emergency-banner"
  class="bg-[#CC1720] text-white text-sm font-medium py-2.5 px-4 text-center flex items-center justify-center gap-3 relative"
  role="alert"
>
  <span class="relative flex h-2 w-2 shrink-0">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
    <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
  </span>
  <span>
    <strong>Emergency service needed?</strong> We respond within 24 hours —
    <a href={`tel:${site.phonePlain}`} class="underline font-bold ml-1">{site.phone}</a>
  </span>
  <button
    id="close-banner"
    class="absolute right-4 top-1/2 -translate-y-1/2 opacity-70 hover:opacity-100 cursor-pointer"
    aria-label="Dismiss"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<script>
  document.getElementById('close-banner')?.addEventListener('click', () => {
    document.getElementById('emergency-banner')?.remove();
  });
</script>
