---
import SectionHeader from './SectionHeader.astro';
import { site } from '../config/site';

interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---

<section class={compact ? 'mb-12' : 'py-20 lg:py-28 bg-white'}>
  <div class={compact ? '' : 'max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'}>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center bg-[#F2F6FC] border border-[#CDD8E8] p-6 lg:p-10">
      <div>
        <SectionHeader
          eyebrow="Roofing Authority"
          title="Built With The Details<br />Homeowners Search For."
          subtitle="Use this reusable block for SEO depth, warranty proof, materials clarity, financing language, and service-area trust — no client case study required."
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-6">
          {[
            'Roof condition documentation',
            'Material and warranty guidance',
            'Installation process clarity',
            'Local service-area proof',
          ].map((item) => (
            <div class="bg-white border border-[#CDD8E8] px-4 py-3 text-sm text-[#0A1628]">{item}</div>
          ))}
        </div>
      </div>
      <div class="relative">
        <img src="/images/roofing/residential-shingle-roof-13.jpg" alt="Residential asphalt shingle roof" class="w-full h-80 object-cover shadow-lg" loading="lazy" />
        <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur p-4 border border-[#CDD8E8]">
          <p class="font-['Barlow_Condensed'] font-black text-2xl text-[#0A2447] uppercase">{site.warranty}</p>
          <p class="text-[#5B7394] text-xs uppercase tracking-wider">Workmanship proof built into the template</p>
        </div>
      </div>
    </div>
  </div>
</section>
