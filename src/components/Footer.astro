---
import { site, services } from '../config/site';
const year = new Date().getFullYear();
const logoUrl = (site as any).logoUrl;
const logoNeedsPlate = (site as any).logoNeedsPlate ?? false;
---

<footer class="bg-[#0A2447] text-white pt-16 pb-24 md:pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Top grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-5">
          {logoUrl ? (
            <div class:list={["rounded px-3 py-2 inline-flex", logoNeedsPlate ? "bg-[#0A2447]" : "bg-white"]}>
              <img src={logoUrl} alt={`${site.name} logo`} class="max-h-12 w-auto object-contain" loading="lazy" />
            </div>
          ) : (
            <div class="leading-tight border-l-4 border-[#CC1720] pl-3">
              <span class="block font-['Barlow_Condensed'] font-black text-lg tracking-wide text-white uppercase leading-none">{site.name}</span>
              <span class="block font-['Barlow_Condensed'] font-bold text-xs tracking-[0.15em] text-[#CC1720] uppercase leading-none">Septic Services</span>
            </div>
          )}
        </div>
        <p class="text-blue-200/70 text-sm leading-relaxed max-w-xs mb-6">
          {site.tagline} Serving {site.serviceArea.slice(0, 3).join(', ')} and surrounding areas since {site.founded}.
        </p>
        <div class="flex flex-col gap-2 text-sm text-blue-200/70">
          <a href={`tel:${site.phonePlain}`} class="hover:text-[#CC1720] transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="hover:text-[#CC1720] transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            {site.email}
          </a>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#CC1720] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            {site.address.full}
          </span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-xs uppercase tracking-widest mb-5 flex items-center gap-2">
          <span class="w-4 h-0.5 bg-[#CC1720]"></span>
          Services
        </h3>
        <ul class="flex flex-col gap-2.5">
          {services.map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="text-blue-200/70 text-sm hover:text-[#CC1720] transition-colors flex items-center gap-2">
                <span class="w-1 h-1 bg-[#CC1720] rounded-full shrink-0"></span>
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold text-xs uppercase tracking-widest mb-5 flex items-center gap-2">
          <span class="w-4 h-0.5 bg-[#CC1720]"></span>
          Company
        </h3>
        <ul class="flex flex-col gap-2.5 mb-8">
          <li><a href="/about" class="text-blue-200/70 text-sm hover:text-[#CC1720] transition-colors">About Us</a></li>
          <li><a href="/financing" class="text-blue-200/70 text-sm hover:text-[#CC1720] transition-colors">Financing</a></li>
          <li><a href="/blog" class="text-blue-200/70 text-sm hover:text-[#CC1720] transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-blue-200/70 text-sm hover:text-[#CC1720] transition-colors">Contact</a></li>
        </ul>
        <div class="bg-white/5 border border-white/10 p-4 text-xs text-blue-200/60 space-y-1">
          <p>License: {site.license}</p>
          <p>Warranty: {site.warranty}</p>
          <p>$2M General Liability</p>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 mb-6"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-blue-200/50">
      <p>© {year} {site.name}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <span>Licensed · Insured · Locally Owned</span>
      </div>
    </div>
  </div>
</footer>
