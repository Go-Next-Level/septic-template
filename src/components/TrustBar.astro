---
import { site } from '../config/site';

const stats = [
  { label: 'Years in Business', value: `${new Date().getFullYear() - site.founded}+`, icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />` },
  { label: 'Systems Serviced', value: `${site.systemsServiced.toLocaleString()}+`, icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" />` },
  { label: 'Google Rating', value: `${site.rating}★`, icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />` },
  { label: 'Satisfaction Guarantee', value: site.warranty, icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />` },
];
---

<div class="bg-white border-y border-[#CDD8E8] shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-[#CDD8E8]">
      {stats.map((s) => (
        <div class="flex items-center gap-3 md:px-8 md:justify-center">
          <div class="w-9 h-9 rounded-full bg-[#F2F6FC] border border-[#CDD8E8] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={s.icon} />
          </div>
          <div>
            <div class="font-['Barlow_Condensed'] font-bold text-xl text-[#0A2447]">{s.value}</div>
            <div class="text-[#5B7394] text-xs">{s.label}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
