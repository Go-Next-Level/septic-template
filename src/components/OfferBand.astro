---
import { site } from '../config/site';

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  highlights?: string[];
  ctaLabel?: string;
  ctaHref?: string;
}

const offer = site.financing;
const {
  eyebrow = offer.eyebrow,
  title = offer.title,
  body = offer.body,
  highlights = offer.highlights,
  ctaLabel = 'Check Eligibility',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="py-8 bg-[#0A2447] border-y border-white/10" aria-label="Financing and offer details">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden bg-white text-[#0A1628] shadow-2xl">
      <div class="absolute inset-y-0 left-0 w-2 bg-[#CC1720]"></div>
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 p-6 lg:p-8 items-center">
        <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-6 items-center">
          <div class="bg-[#F2F6FC] border border-[#CDD8E8] p-5">
            <p class="text-[#CC1720] text-xs font-bold uppercase tracking-[0.2em] mb-2">{eyebrow}</p>
            <p class="font-['Barlow_Condensed'] text-4xl font-black uppercase leading-none text-[#0A2447]">Premium Service</p>
            <p class="text-[#5B7394] text-xs mt-2">without surprise terms</p>
          </div>
          <div>
            <h2 class="font-['Barlow_Condensed'] font-black text-3xl lg:text-4xl uppercase leading-tight text-[#0A2447]">{title}</h2>
            <p class="text-[#5B7394] leading-relaxed mt-3 max-w-2xl">{body}</p>
            <div class="flex flex-wrap gap-2 mt-5">
              {highlights.map((item) => (
                <span class="inline-flex items-center gap-2 bg-[#F2F6FC] border border-[#CDD8E8] px-3 py-2 text-xs font-semibold text-[#0A2447]">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#CC1720]"></span>
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>
        <a href={ctaHref} class="inline-flex items-center justify-center px-7 py-4 bg-[#CC1720] text-white font-bold text-sm uppercase tracking-wider hover:bg-[#E31C26] transition-colors">
          {ctaLabel}
        </a>
      </div>
    </div>
  </div>
</section>
