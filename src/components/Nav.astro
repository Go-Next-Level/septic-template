---
import { site } from '../config/site';

const logoUrl = (site as any).logoUrl;
const logoNeedsPlate = (site as any).logoNeedsPlate ?? false;
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[#CDD8E8] transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16 lg:h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label={site.name}>
      {logoUrl ? (
        <span class:list={["inline-flex items-center", logoNeedsPlate && "bg-[#0A2447] px-3 py-2 rounded-sm shadow-sm"]}>
          <img src={logoUrl} alt={`${site.name} logo`} class="max-h-12 lg:max-h-14 w-auto object-contain" loading="eager" />
        </span>
      ) : (
        <div class="leading-tight border-l-4 border-[#CC1720] pl-3">
          <span class="block font-['Barlow_Condensed'] font-black text-xl lg:text-2xl tracking-wide text-[#0A2447] uppercase leading-none">
            {site.name}
          </span>
          <span class="block font-['Barlow_Condensed'] font-bold text-sm tracking-[0.15em] text-[#CC1720] uppercase leading-none">
            Septic Services
          </span>
        </div>
      )}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      <a href="/services/roof-replacement" class="text-sm font-medium text-[#5B7394] hover:text-[#0A2447] transition-colors duration-200">Services</a>
      <a href="/about" class="text-sm font-medium text-[#5B7394] hover:text-[#0A2447] transition-colors duration-200">About</a>
      <a href="/financing" class="text-sm font-medium text-[#5B7394] hover:text-[#0A2447] transition-colors duration-200">Financing</a>
      <a href="/blog" class="text-sm font-medium text-[#5B7394] hover:text-[#0A2447] transition-colors duration-200">Blog</a>
      <a
        href={`tel:${site.phonePlain}`}
        class="flex items-center gap-1.5 text-sm font-semibold text-[#0A2447] hover:text-[#CC1720] transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {site.phone}
      </a>
      <a
        href="/contact"
        class="px-5 py-2.5 bg-[#CC1720] text-white text-sm font-semibold hover:bg-[#E31C26] transition-colors duration-200 cursor-pointer rounded-sm"
      >
        Free Quote
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-[#0A2447] transition-all duration-200 origin-center" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-[#0A2447] transition-all duration-200" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-[#0A2447] transition-all duration-200 origin-center" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white border-t border-[#CDD8E8] px-4 py-6 flex flex-col gap-4 shadow-lg"
  >
    <a href="/services/roof-replacement" class="text-[#0A2447] font-semibold py-2 border-b border-[#CDD8E8]">Services</a>
    <a href="/about" class="text-[#0A2447] font-semibold py-2 border-b border-[#CDD8E8]">About</a>
    <a href="/financing" class="text-[#0A2447] font-semibold py-2 border-b border-[#CDD8E8]">Financing</a>
    <a href="/blog" class="text-[#0A2447] font-semibold py-2 border-b border-[#CDD8E8]">Blog</a>
    <a href={`tel:${site.phonePlain}`} class="text-[#CC1720] font-bold py-2">{site.phone}</a>
    <a href="/contact" class="mt-2 block text-center py-3 bg-[#CC1720] text-white font-semibold rounded-sm">Free Quote</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    menu.classList.toggle('hidden', !open);
    if (open) {
      bar1.style.transform = 'translateY(8px) rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
  });
</script>
