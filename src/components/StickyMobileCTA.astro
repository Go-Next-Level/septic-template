---
import { site } from '../config/site';

interface Props {
  quoteLabel?: string;
  phoneLabel?: string;
}

const { quoteLabel = 'Free Inspection', phoneLabel = 'Call Now' } = Astro.props;
---

<div class="fixed bottom-0 left-0 right-0 z-40 md:hidden border-t border-[#CDD8E8] bg-white/95 backdrop-blur shadow-[0_-10px_30px_rgba(10,36,71,0.18)]" aria-label="Quick contact actions">
  <div class="grid grid-cols-2">
    <a href={`tel:${site.phonePlain}`} class="flex items-center justify-center gap-2 py-4 bg-[#CC1720] text-white font-bold text-sm uppercase tracking-wider">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
      </svg>
      {phoneLabel}
    </a>
    <a href="/contact" class="flex items-center justify-center gap-2 py-4 bg-[#0A2447] text-white font-bold text-sm uppercase tracking-wider">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#CC1720]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {quoteLabel}
    </a>
  </div>
</div>
